# ── Руслан — файл API-ключей ──
# Скопируй этот файл в ~/.hermes/.env и заполни нужные ключи
# Файл .env — секретный! Никому не показывай.

# ══════════════════════════════════════════════════
#  🤖 LLM-провайдер (выбери один, раскомментируй)
# ══════════════════════════════════════════════════

# ── OpenRouter (200+ моделей, есть бесплатные) ──
# Регистрация: https://openrouter.ai/keys (2 минуты, карта не нужна)
# Бесплатные модели: qwen/qwen3-coder:free, deepseek/deepseek-r1:free
OPENROUTER_API_KEY=sk-or-v1-твой-ключ-здесь

# ── DeepSeek (прямой API, дёшево, отличный русский) ──
# Ключ: https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=твой-ключ

# ── Groq (быстрые бесплатные модели) ──
# Ключ: https://console.groq.com/keys
# GROQ_API_KEY=твой-ключ

# ── OpenCode/Zen (бесплатный DeepSeek) ──
# Ключ: https://opencode.ai
# OPENCODE_GO_API_KEY=твой-ключ

# ══════════════════════════════════════════════════
#  📱 Telegram
# ══════════════════════════════════════════════════
# Получи токен у @BotFather в Telegram (/newbot)
# TELEGRAM_BOT_TOKEN=1234567890:AAExxxxxx-yyy...

# ══════════════════════════════════════════════════
#  🦙 Ollama (локально, без ключа — не нужен здесь)
# ══════════════════════════════════════════════════
# Ollama работает без ключей. Просто установи:
#   curl -fsSL https://ollama.com/install.sh | sh
#   ollama pull qwen2.5:1.5b
